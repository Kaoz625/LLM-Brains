# Embedding backend: "openai" or "ollama"
EMBEDDING_BACKEND=openai

# OpenAI API key (required when EMBEDDING_BACKEND=openai)
OPENAI_API_KEY=sk-...

# OpenAI model for LLM compilation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# LLM backend for compiler: "openai" or "ollama"
LLM_BACKEND=openai

# Ollama settings (required when using ollama backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here_optional
BRAIN_DIR=./brain
WATCH_INTERVAL=60
